{   
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ES2020",
        "jsx": "react",
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "baseUrl": ".",
        "paths": {
          "@/components/*": ["components/*"],
          "@/data/*": ["data/*"],
          "@/layouts/*": ["layouts/*"],
          "@/lib/*": ["lib/*"],
          "@/styles/*": ["styles/*"]
        }
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}